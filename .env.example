OPENAI_API_KEY=sk-...
UPLOADPOST_API_KEY=...
UPLOADPOST_USER=...

# Google OAuth
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_EMPRESA_EMAIL=inmersivagrupoinmobiliario@gmail.com

# Seguridad de sesión
SESSION_SECRET=cambia-esto-por-una-clave-segura

# Dominio corporativo de corredores (bloquea login Google con este dominio)
COMPANY_EMAIL_DOMAIN=inmersiva.com

# Cloudflare Email Routing — crea alias @inmersiva.com automáticamente al aprobar corredor
# Token en: dash.cloudflare.com → My Profile → API Tokens → permisos: Zone · Email Routing (Edit)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# SMTP para enviar credenciales al corredor (Gmail + App Password recomendado)
# Activa contraseñas de app en: myaccount.google.com/security → Contraseñas de aplicaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=inmersivagrupoinmobiliario@gmail.com
SMTP_PASSWORD=
SMTP_FROM=inmersivagrupoinmobiliario@gmail.com

CLOUDFLARE_API_TOKEN=tu_token
CLOUDFLARE_ZONE_ID=tu_zone_id
SMTP_PASSWORD=tu_app_password_gmail
